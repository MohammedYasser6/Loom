<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="1024.0" styleClass="home-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.loom.app.HomePageController">

    <VBox spacing="15" styleClass="home-card" maxWidth="400">

        <Label text="Welcome to Loom" styleClass="home-title" />
        <Label text="Enter your display name to get started." styleClass="home-subtitle" />

        <VBox spacing="5">
            <Label text="DISPLAY NAME" style="-fx-text-fill: #949ba4; -fx-font-size: 11px; -fx-font-weight: bold;" />
            <TextField fx:id="nameInput" promptText="How should we call you?" styleClass="home-input" />
            <Label fx:id="errorLabel" textFill="#fa777c" /> </VBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Host Workspace" styleClass="button, host-button" onAction="#handleHostAction" prefWidth="150" />
            <Button text="Join Workspace" styleClass="button, join-button" onAction="#handleJoinAction" prefWidth="150" />
        </HBox>

    </VBox>

</VBox>