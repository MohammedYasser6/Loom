<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1200.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.loom.app.MainDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar">
            <Label text="LOOM" styleClass="logo-text" />
            <HBox HBox.hgrow="ALWAYS" />
            <Label fx:id="networkStatusLabel" style="-fx-text-fill: #00ffcc; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.25" styleClass="main-split">
            <items>

                <VBox minWidth="280.0" spacing="15" styleClass="sidebar">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="TEAM CHAT" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #949ba4;" />
                        <HBox HBox.hgrow="ALWAYS" />
                        <Button text="Audit Tasks" onAction="#handleAuditTasks" style="-fx-font-size: 10px; -fx-background-color: #4e5058; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-scroll-pane">
                        <VBox fx:id="chatHistoryBox" spacing="8" />
                    </ScrollPane>

                    <HBox alignment="CENTER" spacing="8">
                        <Button text="+" onAction="#handleAttachFile" style="-fx-background-color: #4e5058; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <TextField fx:id="chatInput" promptText="Message #team..." HBox.hgrow="ALWAYS" styleClass="chat-input" onAction="#handleSendMessage" />
                    </HBox>
                </VBox>

                <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <HBox spacing="20" style="-fx-padding: 20;" alignment="TOP_LEFT">

                        <VBox fx:id="todoColumn" styleClass="kanban-column" spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="To Do" styleClass="kanban-header" />
                                <HBox HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="boardSortDropdown" promptText="Sort..." styleClass="chat-input" style="-fx-font-size: 11px; -fx-padding: 4 8 4 8;" />
                            </HBox>

                            <VBox spacing="10" styleClass="creation-card">

                                <TextArea fx:id="newTaskInput" promptText="What needs to be done?" styleClass="chat-input" wrapText="true" prefRowCount="2"/>

                                <HBox spacing="8" alignment="CENTER_RIGHT">
                                    <ComboBox fx:id="assigneeDropdown" promptText="Assign..." visible="false" managed="false" styleClass="chat-input" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="90"/>
                                    <Button text="Add" onAction="#handleAddTask" style="-fx-background-color: #5865F2; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 12 6 12; -fx-background-radius: 4; -fx-cursor: hand;" minWidth="-Infinity"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox fx:id="inProgressColumn" styleClass="kanban-column" spacing="12">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="In Progress" styleClass="kanban-header" />
                            </HBox>
                        </VBox>

                        <VBox fx:id="doneColumn" styleClass="kanban-column" spacing="12">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Done" styleClass="kanban-header" />
                            </HBox>
                        </VBox>

                    </HBox>
                </ScrollPane>

            </items>
        </SplitPane>
    </center>
</BorderPane>